# Données générées. Le CI régénère les indés à chaque déploiement, mais l'API
# Pathé bloque les IP datacenter du CI : on versionne donc la photo Pathé,
# collectée en local, pour que le build s'en serve (indés frais + Pathé figé).
data/*
!data/pathe_cinemas.json
!data/pathe_movies.json
!data/pathe_showtimes.json
!data/pathe_cities.json
!data/cgr_cinemas.json
!data/cgr_movies.json
!data/cgr_showtimes.json
!data/cgr_cities.json
!data/ugc_cinemas.json
!data/ugc_movies.json
!data/ugc_showtimes.json
!data/ugc_cities.json
!data/grandecran_cinemas.json
!data/grandecran_movies.json
!data/grandecran_showtimes.json
!data/grandecran_cities.json
!data/tmdb.json
site/

__pycache__/
*.pyc
